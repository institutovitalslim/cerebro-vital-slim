        {"nome": "Prolactina", "valor": "24,7", "unit": "ng/mL", "ref": "4.04 a 15.2", "status": "crit", "grupo": "hormonal"},
        {"nome": "PCR-us", "valor": "3,49", "unit": "mg/L", "ref": "<3.0", "status": "alert", "grupo": "inflamatorio"},
