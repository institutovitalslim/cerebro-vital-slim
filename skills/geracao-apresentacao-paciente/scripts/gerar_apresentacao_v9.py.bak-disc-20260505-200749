def _grupo_de(nome_exame):
    nome_lower = (nome_exame or "").lower()
    for gid, _, exames in GRUPOS_EXAMES_DEF:
        for e in exames:
            if e.lower() in nome_lower or nome_lower in e.lower():
                return gid
    return "outros"


def _sev_from_status(status):
    s = (status or "").upper().strip()
    # Códigos curtos do extrair_exames_pdf: crit/alert/attn/baixo/normal/otimo
    short_map = {"CRIT": "crit", "ALERT": "alert", "ATTN": "attn",
                 "BAIXO": "low", "NORMAL": "ok", "OTIMO": "ok", "ÓTIMO": "ok"}
    if s in short_map:
        return short_map[s]
    # Strings longas (do mock + outras fontes)
    if "CRITICO" in s or "CRÍTICO" in s or "MUITO" in s:
        return "crit"
    if "ALTERADO" in s or "ALTO" in s or "ELEVADO" in s:
        return "alert"
    if "ATENCAO" in s or "ATENÇÃO" in s or "LIMITROFE" in s or "LIMÍTROFE" in s:
        return "attn"
    if "SUPRIMIDO" in s or "DEFICIE" in s or "BAIXO" in s:
        return "low"
    if "NORMAL" in s or "OK" in s:
        return "ok"
    return "ok"


def _sev_label(sev):
    return SEV_LABELS.get(sev, "—")


def process_exames_input(raw):
    import re
    processed = []
    for ex in (raw or []):
        if not isinstance(ex, dict):
            continue
        nome = ex.get("nome") or ex.get("exame") or ex.get("name") or ""
        if not nome:
            continue
        valor = ex.get("valor") or ex.get("value") or "—"
        ref = ex.get("ref") or ex.get("referencia") or ex.get("reference") or "—"
        unit = ex.get("unit") or ex.get("unidade") or ""
        status = ex.get("status") or ex.get("classificacao") or "NORMAL"
        sev = _sev_from_status(status)
        grupo = _grupo_de(nome)
        delta = 0
        try:
            v = float(str(valor).replace(",", ".").replace("<", "").replace(">", ""))
            r = str(ref)
            m = re.search(r"([\d,\.]+)\s*[-aà]\s*([\d,\.]+)", r)
            if m:
                lo = float(m.group(1).replace(",", "."))
                hi = float(m.group(2).replace(",", "."))
                if v > hi:
                    delta = (v - hi) / max(hi, 0.001)
                elif v < lo:
                    delta = (lo - v) / max(lo, 0.001)
        except Exception:
            pass
        processed.append({
            "nome": nome, "valor": str(valor), "ref": str(ref), "unit": unit,
            "status": status, "sev": sev, "grupo": grupo, "delta": delta,
        })
    return processed


def render_alertas_criticos(exames_processed):
    rank = {"crit": 0, "alert": 1, "low": 2, "attn": 3, "ok": 4}
    sorted_ex = sorted(exames_processed, key=lambda e: (rank.get(e.get("sev", "ok"), 9), -float(e.get("delta", 0))))
    top4 = [e for e in sorted_ex if e.get("sev") in ("crit", "alert", "low", "attn")][:4]
    if not top4:
        return ""
    cards = []
    for i, ex in enumerate(top4):
        delay = (i + 1) * 100
        cards.append(
            '<div class="alerta-card" data-sev="' + ex['sev'] + '" data-reveal data-delay="' + str(delay) + '">' +
            '<div class="nome">' + safe_html(ex['nome']) + '</div>' +
            '<div class="valor">' + safe_html(ex['valor']) + '<span class="unit">' + safe_html(ex.get('unit', '')) + '</span></div>' +
            '<div class="ref">Ref: ' + safe_html(ex.get('ref', '—')) + '</div>' +
            '<div class="status">' + _sev_label(ex['sev']) + '</div>' +
            '</div>'
        )
    return '<div class="alertas-grid">' + "".join(cards) + '</div>'


def render_grupos_exames(exames_processed):
    by_group = {}
    for ex in exames_processed:
        g = ex.get("grupo") or _grupo_de(ex["nome"])
        by_group.setdefault(g, []).append(ex)
    blocos = []
    for gid, gnome, _ in GRUPOS_EXAMES_DEF:
        items = by_group.get(gid, [])
        if not items:
            continue
        rows = []
        for ex in items:
            rows.append(
                '<div class="exame-row" data-sev="' + ex.get('sev', 'ok') + '">' +
                '<div class="e-nome">' + safe_html(ex['nome']) + '</div>' +
                '<div class="e-valor">' + safe_html(ex['valor']) + ' <span style="font-size: 12px; color: var(--text-muted);">' + safe_html(ex.get('unit', '')) + '</span></div>' +
                '<div class="e-ref">' + safe_html(ex.get('ref', '—')) + '</div>' +
                '<div class="e-status">' + _sev_label(ex.get('sev', 'ok')) + '</div>' +
                '</div>'
            )
        alterados = sum(1 for e in items if e.get("sev") != "ok")
        blocos.append(
            '<div class="grupo-exame" data-reveal>' +
            '<div class="grupo-header">' +
            '<h3>' + safe_html(gnome) + '</h3>' +
            '<div class="grupo-count">' + str(alterados) + '/' + str(len(items)) + ' alterações</div>' +
            '</div>' +
            "".join(rows) +
            '</div>'
        )
    return '<div class="grupos-exames">' + "".join(blocos) + '</div>'


