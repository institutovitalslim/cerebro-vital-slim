        '<div class="stat-card"><div class="stat-label">Energia e disposição</div>' +
        '<div class="stat-value">Sono ' + safe_html(sono) + '/5 · Energia ' + safe_html(energia) + '/5</div>' +
        '<div class="stat-detail">Como seu corpo está respondendo no dia a dia. Não é "frescura" — é dado clínico.</div></div>' +
        '</div></div>'
    )


def render_spin_problema(paciente, questionario, exames):
    dados_q = (questionario or {}).get("pre-consulta", {}).get("dados", {})
    if not dados_q and isinstance(questionario, dict) and "dados" in questionario:
        dados_q = questionario["dados"]
    queixa = dados_q.get("queixaPrincipal") or dados_q.get("spin_p_principalIncomodo") or ""
    conexoes = []
    for ex in exames:
        if ex.get("sev") not in ("crit", "alert", "low"):
            continue
        nome_lower = ex["nome"].lower()
        sintoma = None
        for k, v in SINTOMA_MAP.items():
            if k in nome_lower:
                sintoma = v
                break
        if sintoma:
            conexoes.append({"exame": ex["nome"], "valor": ex["valor"], "sintoma": sintoma})
    conexoes = conexoes[:6]
    if not conexoes:
        return ""
    cards = []
    for i, c in enumerate(conexoes):
        delay = (i + 1) * 100
        cards.append(
            '<div class="problema-card" data-reveal data-delay="' + str(delay) + '">' +
            '<div class="descricao">' +
            '<span class="exame-tag">' + safe_html(c['exame']) + '</span>' +
            '<span class="exame-valor-tag">' + safe_html(c['valor']) + ' — Alterado</span>' +
            '<h4 style="font-family: var(--serif); font-size: 17px; font-weight: 500; color: var(--gold-dark); text-transform: none; letter-spacing: 0; margin-bottom: var(--s-2);">Sintomas:</h4>' +
            '<p style="font-size: 17px; color: var(--text-body); line-height: 1.55; margin: 0;">' + safe_html((c['sintoma'][:1].upper() + c['sintoma'][1:]) if c.get('sintoma') else '') + '</p>' +
            '</div></div>'
        )
    queixa_block = ""
    if queixa:
        queixa_block = '<p style="font-family: var(--serif); font-style: italic; font-size: 22px; color: var(--text-dark); text-align: center; max-width: 760px; margin: 0 auto var(--s-7);">"' + safe_html(queixa) + '"</p>'
    return (
        '<div class="spin-step" data-reveal>' +
        '<div class="spin-step-header"><div class="spin-num">02</div>' +
        '<div class="spin-step-title">' +
        '<span class="step-eyebrow">Problema</span>' +
        '<h3>Os sinais que seu corpo está dando</h3>' +
        '<p class="lead">Aquilo que você sente não é coincidência. Os exames mostram exatamente onde o sistema está pedindo socorro.</p>' +
        '</div></div>' +
        queixa_block +
        '<div class="problemas-grid">' + "".join(cards) + '</div>' +
        '</div>'
    )


def render_spin_implicacao(paciente, exames, biblioteca):
    rules = (biblioteca or {}).get("rules", [])
    if not rules or not exames:
        return ""
    matched = []
    seen_ids = set()
    for ex in exames:
        if ex.get("sev") not in ("crit", "alert", "low"):
            continue
        for rule in rules:
            if rule["id"] in seen_ids:
                continue
            if _matches_rule(rule, ex, paciente):
                matched.append((ex, rule))
                seen_ids.add(rule["id"])
    if not matched:
        return ""
    cards = []
    for i, (ex, rule) in enumerate(matched[:6]):
        delay = (i + 1) * 100
        impl = rule.get("implicacao", {})
        horizons = []
        for h_label, h_text in impl.items():
            if h_label in ("6m", "1ano", "3anos"):
                label_pretty = {"6m": "Em 6 meses", "1ano": "Em 1 ano", "3anos": "Em 3 anos"}[h_label]
                horizons.append(
                    '<div class="horizonte"><div class="h-label">' + label_pretty + '</div>' +
                    '<div class="h-text">' + safe_html(h_text) + '</div></div>'
                )
        if not horizons and "geral" in impl:
            horizons.append(
                '<div class="horizonte" style="grid-column: 1/-1;"><div class="h-label">Implicação clínica</div>' +
                '<div class="h-text">' + safe_html(impl["geral"]) + '</div></div>'
            )
        evidencia = rule.get("evidencia", {})
        pmid = evidencia.get("pmid", "")
        # Usar search query robusta (sempre funciona) ao invés de PMID exato (alguns saem do ar)
        titulo_estudo = evidencia.get("titulo_estudo", "")
        # Construir search URL a partir do título
        import urllib.parse as _up
        if titulo_estudo:
            url = "https://pubmed.ncbi.nlm.nih.gov/?term=" + _up.quote(titulo_estudo)
        else:
            url = evidencia.get("url", "https://pubmed.ncbi.nlm.nih.gov/" + pmid + "/")
        titulo_estudo = evidencia.get("titulo_estudo", "")
        sev = ex.get("sev", "alert")
        grav = "alta" if sev == "crit" else ("media" if sev == "alert" else "baixa")
        cards.append(
            '<div class="implicacao-card" data-grav="' + grav + '" data-reveal data-delay="' + str(delay) + '">' +
            '<div class="implicacao-header">' +
            '<span class="trigger">' + safe_html(ex['nome']) + '<span class="trigger-valor">' + safe_html(ex['valor']) + safe_html(ex.get('unit', '')) + '</span></span>' +
            '<h4>' + safe_html(rule.get("titulo", "")) + '</h4>' +
            '</div>' +
            '<div class="horizontes">' + "".join(horizons) + '</div>' +
            '<div class="implicacao-decisao">' + safe_html(rule.get("decisao", "")) + '</div>' +
            '<div class="implicacao-evidencia">' +
            '<span>' + safe_html(titulo_estudo) + '</span>' +
            '<a class="pubmed-badge" href="' + safe_html(url) + '" target="_blank" rel="noopener">PubMed PMID ' + safe_html(pmid) + '</a>' +
            '</div></div>'
        )
    return (
        '<div class="spin-step" data-reveal>' +
        '<div class="spin-step-header"><div class="spin-num">03</div>' +
        '<div class="spin-step-title">' +
        '<span class="step-eyebrow">Implicação</span>' +
        '<h3>Para onde isso leva, sem mudança</h3>' +
        '<p class="lead">Cada alteração tem um caminho conhecido pela ciência. Cada mês sem corrigir é um passo dado nessa direção.</p>' +
        '</div></div>' +
        '<div class="implicacoes-list">' + "".join(cards) + '</div>' +
        '</div>'
    )


