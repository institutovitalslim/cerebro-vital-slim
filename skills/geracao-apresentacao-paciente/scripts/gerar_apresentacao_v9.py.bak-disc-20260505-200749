def _matches_rule(rule, exame, paciente):
    trig = rule.get("trigger", {})
    if not trig:
        return False
    target_exame = (trig.get("exame") or "").lower()
    if not target_exame:
        return False
    if target_exame not in exame["nome"].lower() and exame["nome"].lower() not in target_exame:
        return False
    op = trig.get("operador")
    val = trig.get("valor")
    if val is None or op is None:
        return rule.get("trigger", {}).get("categoria") == exame.get("grupo")
    try:
        e_val = float(str(exame["valor"]).replace(",", ".").replace("<", "").replace(">", ""))
    except Exception:
        return False
    sexo = paciente.get("sexo", "M") or "M"
    if trig.get("sexo") and trig["sexo"] != sexo:
        return False
    if op == ">":
        return e_val > val
    if op == "<":
        return e_val < val
    if op == "entre":
        try:
            lo, hi = val
            return lo <= e_val <= hi
        except Exception:
            return False
    return False



# Tradução clínica: grupo de exame → impacto funcional sentido pelo paciente
GRUPO_IMPACTO_FUNCIONAL = {
    "glicidico":     "controle de energia, fome e peso",
    "lipidico":      "risco cardiovascular silencioso",
    "hormonal":      "libido, disposição e composição corporal",
    "tireoide":      "metabolismo, temperatura e humor",
    "hepatico":      "digestão e capacidade de eliminar toxinas",
    "renal":         "filtração e retenção de líquidos",
    "inflamatorio":  "inflamação silenciosa e recuperação",
    "vitaminas":     "imunidade, energia celular e ossos",
    "hemograma":     "oxigenação e defesa imune",
    "adrenal":       "resposta ao estresse e disposição matinal",
    "outros":        "ajustes pontuais",
}

GRUPO_NOME_AMIGAVEL = {
    "glicidico":     "Açúcar e energia",
    "lipidico":      "Colesterol e cardiovascular",
    "hormonal":      "Hormônios sexuais",
    "tireoide":      "Tireoide",
    "hepatico":      "Fígado",
    "renal":         "Rins",
    "inflamatorio":  "Inflamação",
    "vitaminas":     "Vitaminas e minerais",
    "hemograma":     "Sangue",
    "adrenal":       "Adrenal e estresse",
    "outros":        "Outros",
}


def _resumo_metabolico_clinico(exames):
    """
    Constrói narrativa do stat-card 'Saúde metabólica' baseada nos sistemas afetados.

    Returns:
        (stat_value, stat_detail) — strings para o card.
    """
    alterados_por_grupo = {}
    for e in exames:
        if e.get("sev") in ("crit", "alert", "low"):
            g = e.get("grupo", "outros")
            alterados_por_grupo.setdefault(g, []).append(e)

    if not alterados_por_grupo:
        return ("Quadro estável", "Todos os marcadores principais dentro da faixa funcional.")

    n_sistemas = len(alterados_por_grupo)
    n_alterados = sum(len(v) for v in alterados_por_grupo.values())

    # Stat value — frase principal
    if n_sistemas == 1:
        stat_value = f"1 sistema pede ajuste"
    else:
        stat_value = f"{n_sistemas} sistemas pedem ajuste"

    # Stat detail — sistemas afetados + impacto funcional
    # Ordena pelos grupos com mais alterações
    ordenados = sorted(alterados_por_grupo.items(), key=lambda x: -len(x[1]))
    sistemas_str = []
    for grupo, lst in ordenados[:4]:  # top 4 sistemas
        nome_amigavel = GRUPO_NOME_AMIGAVEL.get(grupo, grupo.capitalize())
        impacto = GRUPO_IMPACTO_FUNCIONAL.get(grupo, "")
        if impacto:
            sistemas_str.append(f"<strong>{nome_amigavel}</strong> ({impacto})")
        else:
            sistemas_str.append(f"<strong>{nome_amigavel}</strong>")

    if len(ordenados) > 4:
        sistemas_str.append(f"+ {len(ordenados) - 4} outros")

    detail = (
        f"{n_alterados} marcadores apontam para áreas que afetam seu dia a dia: "
        + " · ".join(sistemas_str) + "."
    )
    return (stat_value, detail)


def render_spin_situacao(paciente, questionario, exames):
    dados_q = (questionario or {}).get("pre-consulta", {}).get("dados", {})
    if not dados_q and isinstance(questionario, dict) and "dados" in questionario:
        dados_q = questionario["dados"]
    peso = dados_q.get("pesoAtual") or "—"
    altura = dados_q.get("altura") or "—"
    imc = "—"
    try:
        if peso != "—" and altura != "—":
            p = float(str(peso).replace(",", "."))
            a = float(str(altura).replace(",", "."))
            if a > 3:
                a = a / 100
            imc = str(round(p / (a*a), 1))
    except Exception:
        pass
    alterados = sum(1 for e in exames if e.get("sev") in ("crit", "alert", "low"))
    total = len(exames)
    _resumo_clin = _resumo_metabolico_clinico(exames)
    sono = dados_q.get("qualidadeSono") or "—"
    energia = dados_q.get("nivelEnergia") or "—"
    return (
        '<div class="spin-step" data-reveal>' +
