        '</div></div>' +
        '<div class="situacao-stats">' +
        '<div class="stat-card"><div class="stat-label">Composição corporal</div>' +
        '<div class="stat-value">' + safe_html(peso) + ' kg · IMC ' + safe_html(imc) + '</div>' +
        '<div class="stat-detail">Altura ' + safe_html(altura) + ' m · referência clínica para acompanhamento.</div></div>' +
        '<div class="stat-card"><div class="stat-label">Saúde metabólica</div>' +
