def _q_card(label: str, value: str, sub: str = "", icon: str = "", feature: bool = False, list_items: list = None, delay: int = 0) -> str:
    cls = "q-card feature" if feature else "q-card"
    delay_attr = f' data-delay="{delay}"' if delay else ""
    sub_html = f'<div class="sub">{safe_html(sub)}</div>' if sub else ""
    list_html = ""
    if list_items:
        items = "".join(f"<li>{safe_html(i)}</li>" for i in list_items)
        list_html = f'<ul class="list">{items}</ul>'
    return f"""
<div class="{cls}" data-reveal{delay_attr}>
  <div class="icon">{icon}</div>
  <div class="label">{safe_html(label)}</div>
  <div class="value">{safe_html(value)}</div>
  {sub_html}
  {list_html}
</div>
"""


def render_questionario(questionario: dict, paciente: dict = None) -> str:
    dados = questionario.get("pre-consulta", {}).get("dados", {}) if questionario else {}
    if not dados and isinstance(questionario, dict) and "dados" in questionario:
        dados = questionario["dados"]

    paciente = paciente or {}
    idade = dados.get("idade") or paciente.get("idade") or calcular_idade(paciente.get("dataNascimento")) or "—"
    peso = dados.get("pesoAtual") or dados.get("peso") or "—"
    altura = dados.get("altura") or "—"
    queixa = dados.get("queixaPrincipal") or dados.get("spin_p_principalIncomodo") or "—"
    tempo = dados.get("spin_s_tempoLuta") or dados.get("tempoLuta") or "—"
    if isinstance(tempo, list):
        tempo = ", ".join(tempo)
    sono = dados.get("qualidadeSono") or "—"
    if sono != "—":
        sono = f"{sono}/5"
    alimentacao = dados.get("alimentacaoFimSemana") or dados.get("alimentacao") or "—"
    if isinstance(alimentacao, list):
        alimentacao = ", ".join(alimentacao)
    motivo = dados.get("spin_n_vidaResolvida") or dados.get("motivoIVS") or "—"
    tentativas = dados.get("tentativasAnteriores") or dados.get("jaTentou") or []
    if isinstance(tentativas, str):
        tentativas = [tentativas]

    # IMC
    imc_str = "—"
    try:
        if peso != "—" and altura != "—":
            p = float(str(peso).replace(",", "."))
            a = float(str(altura).replace(",", "."))
            if a > 3:
                a = a / 100
            imc = round(p / (a * a), 1)
            if imc < 18.5:
                cat = "Abaixo"
            elif imc < 25:
                cat = "Normal"
            elif imc < 30:
                cat = "Sobrepeso"
            elif imc < 35:
                cat = "Obesidade I"
            elif imc < 40:
                cat = "Obesidade II"
            else:
                cat = "Obesidade III"
            imc_str = f"{imc} · {cat}"
    except Exception:
        pass

    cards_html = (
        _q_card("Idade", f"{idade}", "anos", icon='<svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0 1 16 0v1"/></svg>', delay=100)
        + _q_card("Peso atual", f"{peso} kg", f"IMC {imc_str}", icon='<svg viewBox="0 0 24 24"><path d="M12 4v3m0 0H7l-3 7a4 4 0 0 0 8 0l-3-7m3 0h5l3 7a4 4 0 0 1-8 0l3-7M4 21h16"/></svg>', delay=150)
        + _q_card("O que mais te incomoda hoje", queixa, feature=True, icon='<svg viewBox="0 0 24 24"><path d="M21 12a8 8 0 0 1-12.5 6.6L3 21l2.4-5.5A8 8 0 1 1 21 12z"/></svg>', delay=200)
        + _q_card("Há quanto tempo", tempo, icon='<svg viewBox="0 0 24 24"><path d="M6 2h12M6 22h12M7 2v4a5 5 0 0 0 10 0V2M7 22v-4a5 5 0 0 1 10 0v4"/></svg>', delay=300)
        + _q_card("Já tentou", "", list_items=tentativas if tentativas else ["—"], icon='<svg viewBox="0 0 24 24"><path d="M3 12a9 9 0 0 1 15-6.7L21 8m0-5v5h-5M21 12a9 9 0 0 1-15 6.7L3 16m0 5v-5h5"/></svg>', delay=350)
        + _q_card("Qualidade do sono", sono, icon='<svg viewBox="0 0 24 24"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>', delay=400)
        + _q_card("Alimentação", alimentacao, icon='<svg viewBox="0 0 24 24"><path d="M5 3v6a3 3 0 0 0 3 3v9M11 3v6a3 3 0 0 1-3 3M16 3c-2 0-3 2-3 5s1 5 3 5v8M19 3v18"/></svg>', delay=450)
        + _q_card("Por que IVS agora", motivo, icon='<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5"/></svg>', delay=500)
    )

    return f"""
<section id="jornada">
  <div class="wrap">
    <div class="section-header" data-reveal>
      <p class="eyebrow">01 — Sua Jornada</p>
      <h2>O que você nos contou</h2>
      <p class="lead">Cada palavra sua é uma pista. A medicina começa no que o paciente sente.</p>
    </div>
    <div class="q-grid">
      {cards_html}
    </div>
  </div>
</section>
"""


