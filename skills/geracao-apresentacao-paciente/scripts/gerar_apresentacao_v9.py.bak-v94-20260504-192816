# ---------------------------------------------------------------------------
# Main render
# ---------------------------------------------------------------------------
def render_apresentacao_v9(
    paciente: dict,
    questionario: dict | None = None,
    exames: list | None = None,
    output_dir: str | None = None
) -> str:
    """Renderiza apresentação v9 completa em HTML standalone."""
    output_dir = Path(output_dir) if output_dir else Path("/root/cerebro-vital-slim/deliverables")
    output_dir.mkdir(parents=True, exist_ok=True)

    # Load assets
    logo_b64 = img_b64(SITE_IMAGES / "logo-ivs-transparente.png")
    dra_b64 = img_b64(SITE_IMAGES / "dra-daniely-hero.png")

    # Load biblioteca
    biblioteca = {}
    if BIBLIOTECA_PATH.exists():
        try:
            biblioteca = json.loads(BIBLIOTECA_PATH.read_text(encoding="utf-8"))
        except Exception:
            biblioteca = {}

    # Build sections
    nome_completo = paciente.get("nome", "Paciente")
    primeiro_nome = nome_completo.split()[0] if nome_completo else "Paciente"

    html = f"""<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{safe_html(nome_completo)} · Instituto Vital Slim</title>
<meta name="description" content="Apresentação clínica — Dra. Daniely Freitas, CRM-BA 27.588">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
{CSS}
</style>
</head>
<body>
{render_topbar(logo_b64)}
{render_hero({**paciente, "idade": paciente.get("idade") or calcular_idade(paciente.get("dataNascimento"))}, dra_b64)}
{render_questionario(questionario or {})}
{render_exames(exames or [])}
{render_spin(paciente, questionario or {}, exames or [], biblioteca)}
{render_resultados()}
{render_programa()}
{render_cta()}
<script>
{JS}
</script>
</body>
</html>
"""

    # Save
    import re
    nome_slug = re.sub(r"[^a-z0-9-]", "", nome_completo.lower().replace(" ", "-").replace(".", ""))
    from datetime import datetime
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    output_path = output_dir / f"apresentacao-{nome_slug}-v9-{ts}.html"
    output_path.write_text(html, encoding="utf-8")
    return str(output_path)


if __name__ == "__main__":
    # Test render with mock Tiaro data
    paciente = {
        "nome": "Tiaro Fernandes Neves",
        "dataNascimento": 350870400000,
        "data_consulta": "04.05.2026",
    }
    questionario = {
        "pre-consulta": {
            "dados": {
                "pesoAtual": "112",
                "altura": "1.85",
                "queixaPrincipal": "Cansaço, dificuldade pra emagrecer mesmo fazendo dieta e academia",
                "spin_s_tempoLuta": "5+ anos",
                "qualidadeSono": "3",
                "alimentacaoFimSemana": ["Mais flexível, comendo fora"],
                "spin_n_vidaResolvida": "Voltar a sentir energia, libido e disposição como antes",
                "tentativasAnteriores": ["Dieta low-carb", "Academia 5x/semana", "Suplementos avulsos", "Endocrino convencional"],
            }
        }
    }
    exames = []
    output = render_apresentacao_v9(paciente, questionario, exames)
    print(f"✅ Rendered: {output}")
    print(f"   Size: {Path(output).stat().st_size:,} bytes")
