def render_topbar(logo_b64: str) -> str:
    return f"""
<header class="topbar">
  <div class="topbar-inner">
    <img src="{logo_b64}" alt="Instituto Vital Slim" class="logo">
    <div class="doctor-tag">
      <span class="name">Dra. Daniely Freitas</span>
      CRM-BA 27.588 · Médica do Estilo de Vida
    </div>
  </div>
</header>
"""


def render_hero(paciente: dict, dra_b64: str) -> str:
    nome_completo = safe_html(paciente.get("nome", "Paciente"))
    primeiro_nome = nome_completo.split()[0] if nome_completo else "Paciente"
    idade = paciente.get("idade") or calcular_idade(paciente.get("dataNascimento"))
    data_consulta = paciente.get("data_consulta") or date.today().strftime("%d.%m.%Y")

    return f"""
<section class="hero">
  <div class="wrap hero-grid">
    <div class="hero-text" data-reveal>
      <p class="hero-greeting">Apresentação clínica individual</p>
      <h1>Você nos contou. Seus exames <span class="gold">confirmaram</span>. Agora vamos olhar juntos os próximos <span class="gold">180 dias</span>, {primeiro_nome}.</h1>
      <div class="hero-meta">
        <div>
          <span class="label">Paciente</span>
          <span class="value">{nome_completo}</span>
        </div>
        <div>
          <span class="label">Idade</span>
          <span class="value">{idade or '—'} anos</span>
        </div>
        <div>
          <span class="label">Consulta</span>
          <span class="value">{data_consulta}</span>
        </div>
      </div>
    </div>
    <div class="hero-photo" data-reveal data-delay="200">
      <img src="{dra_b64}" alt="Dra. Daniely Freitas">
    </div>
  </div>
  <div class="wrap hero-quote" data-reveal data-delay="500">
    <blockquote>"Cada paciente que chega ao consultório já tentou de tudo. Meu trabalho não é dar mais uma tentativa. É encontrar exatamente onde o sistema está desregulado e corrigi-lo com precisão. <strong>Resultados não são promessas, são consequências de diagnóstico correto.</strong>"</blockquote>
    <cite>Dra. Daniely Freitas</cite>
  </div>
</section>
"""


# ---------------------------------------------------------------------------
# Section: Questionário (Sua Jornada)
# ---------------------------------------------------------------------------
def _q_card(label: str, value: str, sub: str = "", icon: str = "", feature: bool = False, list_items: list = None, delay: int = 0) -> str:
    cls = "q-card feature" if feature else "q-card"
    delay_attr = f' data-delay="{delay}"' if delay else ""
    sub_html = f'<div class="sub">{safe_html(sub)}</div>' if sub else ""
    list_html = ""
    if list_items:
        items = "".join(f"<li>{safe_html(i)}</li>" for i in list_items)
        list_html = f'<ul class="list">{items}</ul>'
    return f"""
<div class="{cls}" data-reveal{delay_attr}>
  <div class="icon">{icon}</div>
  <div class="label">{safe_html(label)}</div>
  <div class="value">{safe_html(value)}</div>
  {sub_html}
  {list_html}
</div>
"""


def render_questionario(questionario: dict) -> str:
    dados = questionario.get("pre-consulta", {}).get("dados", {}) if questionario else {}
    if not dados and isinstance(questionario, dict) and "dados" in questionario:
        dados = questionario["dados"]

    idade = dados.get("idade") or "—"
    peso = dados.get("pesoAtual") or dados.get("peso") or "—"
    altura = dados.get("altura") or "—"
    queixa = dados.get("queixaPrincipal") or dados.get("spin_p_principalIncomodo") or "—"
    tempo = dados.get("spin_s_tempoLuta") or dados.get("tempoLuta") or "—"
    if isinstance(tempo, list):
        tempo = ", ".join(tempo)
    sono = dados.get("qualidadeSono") or "—"
    if sono != "—":
        sono = f"{sono}/5"
    alimentacao = dados.get("alimentacaoFimSemana") or dados.get("alimentacao") or "—"
    if isinstance(alimentacao, list):
        alimentacao = ", ".join(alimentacao)
    motivo = dados.get("spin_n_vidaResolvida") or dados.get("motivoIVS") or "—"
    tentativas = dados.get("tentativasAnteriores") or dados.get("jaTentou") or []
    if isinstance(tentativas, str):
        tentativas = [tentativas]

    # IMC
    imc_str = "—"
    try:
        if peso != "—" and altura != "—":
            p = float(str(peso).replace(",", "."))
            a = float(str(altura).replace(",", "."))
            if a > 3:
                a = a / 100
            imc = round(p / (a * a), 1)
            if imc < 18.5:
                cat = "Abaixo"
            elif imc < 25:
                cat = "Normal"
            elif imc < 30:
                cat = "Sobrepeso"
            elif imc < 35:
                cat = "Obesidade I"
            elif imc < 40:
                cat = "Obesidade II"
            else:
                cat = "Obesidade III"
            imc_str = f"{imc} · {cat}"
    except Exception:
        pass

    cards_html = (
        _q_card("Idade", f"{idade}", "anos", icon="◉", delay=100)
        + _q_card("Peso atual", f"{peso} kg", f"IMC {imc_str}", icon="◯", delay=150)
        + _q_card("O que mais te incomoda hoje", queixa, feature=True, icon="✦", delay=200)
        + _q_card("Há quanto tempo", tempo, icon="◐", delay=300)
        + _q_card("Já tentou", "", list_items=tentativas if tentativas else ["—"], icon="◑", delay=350)
        + _q_card("Qualidade do sono", sono, icon="☾", delay=400)
        + _q_card("Alimentação", alimentacao, icon="◍", delay=450)
        + _q_card("Por que IVS agora", motivo, icon="✧", delay=500)
    )

    return f"""
<section id="jornada">
  <div class="wrap">
    <div class="section-header" data-reveal>
      <p class="eyebrow">01 — Sua Jornada</p>
      <h2>O que você nos contou</h2>
      <p class="lead">Cada palavra sua é uma pista. A medicina começa no que o paciente sente.</p>
    </div>
    <div class="q-grid">
      {cards_html}
    </div>
  </div>
</section>
"""


# ---------------------------------------------------------------------------
# Sections 3-7 — placeholders (Parte 2 e 3)
# ---------------------------------------------------------------------------
