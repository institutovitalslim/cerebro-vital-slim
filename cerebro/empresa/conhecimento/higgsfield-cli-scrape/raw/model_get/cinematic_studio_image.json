  "job_set_type": "cinematic_studio_image",
  "params": [
    {
      "name": "aspect_ratio",
      "type": "string",
      "default": "16:9",
      "required": false,
      "enum": [
        "1:1",
        "4:3",
        "3:4",
        "16:9",
        "9:16",
        "3:2",
        "2:3",
        "21:9"
      ]
    },
    {
      "name": "batch_size",
      "type": "integer",
