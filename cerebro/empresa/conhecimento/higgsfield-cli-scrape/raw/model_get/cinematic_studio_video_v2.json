      "required": false,
      "enum": [
        "auto",
        "action",
        "horror",
        "comedy",
        "western",
        "suspense",
        "intimate",
        "spectacle"
      ]
    },
    {
      "name": "medias",
      "type": "array",
      "default": null,
      "required": false
    },
    {
      "name": "mode",
      "type": "string",
      "default": "std",
      "required": false,
      "enum": [
        "pro",
        "std"
      ]
