{
  "display_name": "Seedance 2.0 Mini",
  "job_set_type": "seedance_2_0_mini",
  "params": [
    {
      "name": "aspect_ratio",
      "type": "string",
      "default": "16:9",
      "required": false,
      "enum": [
        "auto",
        "16:9",
        "9:16",
        "4:3",
        "3:4",
        "1:1",
        "21:9"
      ]
    },
    {
      "name": "bitrate_mode",
      "type": "string",
      "default": "standard",
      "required": false,
      "enum": [
