      "default": 5,
      "required": false
    },
    {
      "name": "generate_audio",
      "type": "boolean",
      "default": true,
      "required": false
    },
    {
      "name": "genre",
      "type": "string",
      "default": "auto",
      "required": false,
      "enum": [
        "auto",
        "action",
        "horror",
        "comedy",
        "noir",
        "drama",
        "epic"
      ]
    },
    {
      "name": "medias",
      "type": "array",
      "default": null,
      "required": false
    },
    {
      "name": "prompt",
      "type": "string",
      "default": null,
      "required": true
