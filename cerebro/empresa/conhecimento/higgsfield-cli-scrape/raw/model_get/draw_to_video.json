      "type": "object",
      "default": null,
      "required": false
    },
    {
      "name": "generate_audio",
      "type": "boolean",
      "default": false,
      "required": false
    },
    {
      "name": "prompt",
      "type": "string",
      "default": null,
      "required": true
    },
    {
